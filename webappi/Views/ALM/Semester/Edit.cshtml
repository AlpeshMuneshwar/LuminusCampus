@model webappi.Data.ErpSemester

@{
    ViewData["Title"] = "Edit Semester";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <er-card title="Edit Semester" subtitle="Modify term details" icon="lni-pencil">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedOn" />
                <input type="hidden" asp-for="CreatedBy" />
                
                <er-select asp-for="ProgramId" label="Program (Degree)" asp-items="ViewBag.ProgramId" icon="lni-graduation" />
                
                <er-input asp-for="Name" label="Semester Name" icon="lni-tag" />
                <er-input asp-for="Code" label="Semester Code" icon="lni-code" />
                <er-input asp-for="SequenceNo" label="Sequence (Order)" type="number" icon="lni-sort-amount-asc" />

                <er-checkbox asp-for="IsActive" label="Is Active" />

                <div class="d-flex gap-2 mt-3">
                    <er-button type="submit" icon="lni-save">Save Changes</er-button>
                    <er-button href="/ALM/Semester" variant="Secondary" icon="lni-arrow-left">Back to List</er-button>
                </div>
            </form>
        </er-card>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
