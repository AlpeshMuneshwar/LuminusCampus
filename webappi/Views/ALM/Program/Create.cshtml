@model webappi.Data.ErpProgram

@{
    ViewData["Title"] = "Create Program";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <er-card title="Create New Program" subtitle="Define a new academic degree" icon="lni-graduation">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <er-input asp-for="Name" label="Program Name" placeholder="e.g. Bachelor of Technology" icon="lni-library" />
                <er-input asp-for="Code" label="Program Code" placeholder="e.g. B.Tech" icon="lni-code" />
                <er-input asp-for="DurationInYears" label="Duration (Years)" type="number" icon="lni-timer" />

                <!-- Checkbox still manual for now as we didn't build taghelper, keeping simple bootstrap for it -->
                <div class="form-check mb-4">
                    <input class="form-check-input" asp-for="IsActive" />
                    <label class="form-check-label" asp-for="IsActive">Is Active</label>
                </div>

                <div class="d-flex gap-2">
                    <er-button type="submit" icon="lni-save">Create Program</er-button>
                    <er-button href="/ALM/Program" variant="Secondary" icon="lni-arrow-left">Back to List</er-button>
                </div>
            </form>
        </er-card>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
