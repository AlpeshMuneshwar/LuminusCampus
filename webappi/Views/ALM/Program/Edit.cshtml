@model webappi.Data.ErpProgram

@{
    ViewData["Title"] = "Edit Program";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <er-card title="Edit Program" subtitle="Modify degree program details" icon="lni-pencil">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedOn" />
                <input type="hidden" asp-for="CreatedBy" />
                
                <er-input asp-for="Name" label="Program Name" icon="lni-library" />
                <er-input asp-for="Code" label="Program Code" icon="lni-code" />
                <er-input asp-for="DurationInYears" label="Duration (Years)" type="number" icon="lni-timer" />

                <er-checkbox asp-for="IsActive" label="Is Active" />

                <div class="d-flex gap-2 mt-3">
                    <er-button type="submit" icon="lni-save">Save Changes</er-button>
                    <er-button href="/ALM/Program" variant="Secondary" icon="lni-arrow-left">Back to List</er-button>
                </div>
            </form>
        </er-card>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
