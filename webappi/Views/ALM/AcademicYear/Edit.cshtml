@model webappi.Data.ErpAcademicYear

@{
    ViewData["Title"] = "Edit Academic Year";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <er-card title="Edit Academic Year" subtitle="Modify session details" icon="lni-pencil">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedOn" />
                <input type="hidden" asp-for="CreatedBy" />
                
                <er-input asp-for="Name" label="Session Name" icon="lni-tag" />
                
                <div class="row">
                    <div class="col-md-6">
                        <er-input asp-for="StartDate" label="Start Date" type="date" icon="lni-calendar" />
                    </div>
                    <div class="col-md-6">
                        <er-input asp-for="EndDate" label="End Date" type="date" icon="lni-calendar" />
                    </div>
                </div>

                <er-checkbox asp-for="IsCurrent" label="Set as Current Active Session" />
                <er-checkbox asp-for="IsActive" label="Is Active" />

                <div class="d-flex gap-2 mt-3">
                    <er-button type="submit" icon="lni-save">Save Changes</er-button>
                    <er-button href="/ALM/AcademicYear" variant="Secondary" icon="lni-arrow-left">Back to List</er-button>
                </div>
            </form>
        </er-card>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
