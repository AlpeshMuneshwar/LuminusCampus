@model IEnumerable<webappi.Data.ErpBranch>

@{
    ViewData["Title"] = "Academic Branches";
}

<er-card title="Academic Branches" subtitle="Manage program specializations and streams" icon="lni-network">
    <div class="mb-3 text-end">
        <er-button href="/ALM/Branch/Create" icon="lni-plus">Add New Branch</er-button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Branch Name</th>
                    <th>Code</th>
                    <th>Program</th>
                    <th>Department</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.Name</div>
                        </td>
                        <td><code>@item.Code</code></td>
                        <td>@item.Program?.Name</td>
                        <td>
                            @if (item.Department != null)
                            {
                                <span>@item.Department.Name</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <er-badge variant="success">Active</er-badge>
                            }
                            else
                            {
                                <er-badge variant="secondary">Inactive</er-badge>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <er-button href="/ALM/Branch/Edit/@item.Id" variant="secondary" size="sm" icon="lni-pencil">Edit</er-button>
                                <er-button type="button" variant="danger" size="sm" icon="lni-trash" onclick="return confirm('Are you sure you want to delete this branch?');">Delete</er-button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</er-card>
