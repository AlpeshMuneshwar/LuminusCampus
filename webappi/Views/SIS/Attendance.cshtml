@{
    ViewData["Title"] = "Student Attendance";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-transparent border-bottom">
        <h5 class="mb-0">Attendance</h5>
    </div>
    <div class="card-body">
        <p class="text-muted">Attendance management interface.</p>
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm"><i class="lni lni-checkmark"></i> Present</button>
            <button class="btn btn-danger btn-sm"><i class="lni lni-close"></i> Absent</button>
        </div>
    </div>
</div>
