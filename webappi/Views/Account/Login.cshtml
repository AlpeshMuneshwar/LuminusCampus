@model webappi.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
@addTagHelper *, webappi

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - LuminusCampus</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link href="https://cdn.lineicons.com/4.0/lineicons.css" rel="stylesheet" />
    
    <!-- Core Styles -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/base/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/components.css" asp-append-version="true" />

    <style>
        body {
            font-family: var(--font-family);
            background-color: #f8fafc; /* Slate 50 */
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-container {
            width: 100%;
            max-width: 1000px;
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08); /* Soft shadow */
            overflow: hidden;
            display: flex;
            min-height: 600px;
            margin: 20px;
        }

        .login-left {
            flex: 1;
            background: #f0f4ff; /* Light bluish tint */
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 2rem;
        }
        
        /* Decorative circle behind image */
        .login-left::before {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: rgba(59, 130, 246, 0.05); /* Very subtle circle */
            border-radius: 50%;
            z-index: 0;
        }

        .login-image {
            max-width: 90%;
            height: auto;
            position: relative;
            z-index: 1;
            filter: drop-shadow(0 10px 20px rgba(0,0,0,0.05));
        }

        .login-right {
            flex: 1;
            padding: 3.5rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #fff;
        }

        .login-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }
        
        .login-header h2 {
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .login-header p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .forgot-password {
            text-align: right;
            margin-bottom: 1.5rem;
        }

        .forgot-password a {
            font-size: 0.85rem;
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
        }

        .login-footer {
            margin-top: 1.5rem;
            text-align: center;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .login-footer a {
            color: var(--primary);
            font-weight: 600;
            text-decoration: none;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .login-container {
                flex-direction: column;
                max-width: 450px;
            }
            .login-left {
                display: none; /* Hide image on mobile for simpler layout */
            }
            .login-right {
                padding: 2rem;
            }
        }
    </style>
</head>
<body>

    <div class="login-container">
        <!-- Left Side: Illustration -->
        <div class="login-left">
            <img src="~/images/login-hero.png" alt="Student Studying" class="login-image">
        </div>

        <!-- Right Side: Form -->
        <div class="login-right">
            <div class="login-header">
                <h2>Welcome Back</h2>
                <p>Please enter your credentials to sign in</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-4">
                    @Html.ValidationSummary(false)
                </div>
            }

            <form asp-action="Login" method="post">
                <er-input asp-for="Email" label="Email Address" icon="lni-user" placeholder="Enter your email" />
                
                <er-input asp-for="Password" label="Password" type="password" icon="lni-lock-alt" placeholder="••••••••" />

                <div class="forgot-password">
                    <a href="#">Forgot Password?</a>
                </div>

                <er-button type="submit" variant="Primary" size="lg" style="width: 100%;">Sign In</er-button>

                <div class="login-footer">
                    Don't have an account? <a href="#">Get Started For Free</a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>
