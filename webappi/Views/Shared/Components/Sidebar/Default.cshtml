@model List<webappi.Services.Interfaces.MenuSection>

<aside id="sidebar" class="expand">
    <div class="sidebar-logo">
        <div class="logo-icon">L</div>
        <a href="#">LuminusCampus</a>
    </div>
    
    <ul class="sidebar-nav">
        @foreach (var menuGroup in Model)
        {
            @if (!string.IsNullOrEmpty(menuGroup.Title))
            {
                <li class="sidebar-header small text-uppercase text-muted fw-bold px-3 mt-3 mb-1">
                    @menuGroup.Title
                </li>
            }

            @foreach (var item in menuGroup.Items)
            {
                <li class="sidebar-item">
                    @if (item.SubItems != null && item.SubItems.Any())
                    {
                        <a href="#menu-@item.Title.Replace(" ", "")" class="sidebar-link has-dropdown collapsed" data-bs-toggle="collapse"
                           aria-expanded="false" aria-controls="menu-@item.Title.Replace(" ", "")">
                            <i class="@item.Icon"></i>
                            <span>@item.Title</span>
                        </a>
                        <ul id="menu-@item.Title.Replace(" ", "")" class="sidebar-dropdown list-unstyled collapse" data-bs-parent="#sidebar">
                            @foreach (var subItem in item.SubItems)
                            {
                                <li class="sidebar-item">
                                    <a href="@subItem.Url" class="sidebar-link">
                                        <span>@subItem.Title</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <a href="@item.Url" class="sidebar-link @(item.IsActive ? "active" : "")">
                            <i class="@item.Icon"></i>
                            <span>@item.Title</span>
                        </a>
                    }
                </li>
            }
        }
    </ul>

    <div class="sidebar-footer">
        <div class="user-profile">
            <div class="user-avatar">
                <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=random&color=fff" width="40" height="40" alt="Avatar">
            </div>
            <div class="user-info">
                <div class="user-name">@User.Identity.Name</div>
                <div class="user-role">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</div>
            </div>
        </div>
        
        <!-- Theme Selector -->
        <div class="mt-3 mb-3">
             <div class="d-flex justify-content-center gap-2 theme-selector-container">
                 <div class="theme-selector-item" data-theme="light" onclick="setTheme('light')" title="Light Theme">
                     <div class="theme-color-preview" style="background: #ffffff; border: 1px solid #ddd;"></div>
                 </div>
                 <div class="theme-selector-item" data-theme="dark" onclick="setTheme('dark')" title="Dark Theme">
                     <div class="theme-color-preview" style="background: #1e1e1e; border: 1px solid #444;"></div>
                 </div>
                 <div class="theme-selector-item" data-theme="green" onclick="setTheme('green')" title="Mint Theme">
                     <div class="theme-color-preview" style="background: #E8F5E9; border: 1px solid #4caf50;"></div>
                 </div>
             </div>
        </div>

        <div class="text-center sidebar-logout-wrapper">
             <form action="/Account/Logout" method="post" id="logoutForm">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-light w-100 sidebar-logout-btn" style="border-radius: 10px; opacity: 0.7;">
                    <i class="lni lni-exit"></i> <span class="logout-text">Logout</span>
                </button>
            </form>
        </div>
    </div>
</aside>
