@model webappi.Data.ErpEmployee

@{
    ViewData["Title"] = "Create Employee";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">New Employee Registration</h3>
    </div>
    <div class="card-body">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <h4 class="mb-4 text-primary">A. Basic Information</h4>
            <div class="row mb-3">
                <div class="col-md-4">
                    <label asp-for="EmployeeCode" class="form-label required">Employee Code</label>
                    <input asp-for="EmployeeCode" class="form-control" placeholder="e.g. EMP001" />
                    <span asp-validation-for="EmployeeCode" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="FirstName" class="form-label required">First Name</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="LastName" class="form-label required">Last Name</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
            
            <div class="row mb-3">
                 <div class="col-md-4">
                    <label asp-for="Gender" class="form-label">Gender</label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">Select Gender</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Photo</label>
                    <input type="file" name="Photo" class="form-control" accept="image/*" />
                </div>
            </div>

            <hr class="my-5"/>

            <h4 class="mb-4 text-primary">B. Contact Information</h4>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ContactNumber" class="form-label">Contact Number</label>
                    <input asp-for="ContactNumber" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label">Address</label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
            </div>
             <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="EmergencyContactName" class="form-label">Emergency Contact Name</label>
                    <input asp-for="EmergencyContactName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="EmergencyContactNumber" class="form-label">Emergency Contact Number</label>
                    <input asp-for="EmergencyContactNumber" class="form-control" />
                </div>
            </div>

            <hr class="my-5"/>

            <h4 class="mb-4 text-primary">C. Employment Details</h4>
            <div class="row mb-3">
                <div class="col-md-4">
                    <label asp-for="DepartmentId" class="form-label required">Department</label>
                    <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId">
                        <option value="">Select Department</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="DesignationId" class="form-label required">Designation</label>
                    <select asp-for="DesignationId" class="form-select" asp-items="ViewBag.DesignationId">
                        <option value="">Select Designation</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="DateOfJoining" class="form-label">Date of Joining</label>
                    <input asp-for="DateOfJoining" type="date" class="form-control" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4">
                    <label asp-for="EmploymentType" class="form-label">Employment Type</label>
                    <select asp-for="EmploymentType" class="form-select">
                        <option value="Full-time">Full-time</option>
                        <option value="Part-time">Part-time</option>
                        <option value="Contract">Contract</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                        <option value="On Leave">On Leave</option>
                    </select>
                </div>
                 <div class="col-md-4">
                    <label asp-for="UserId" class="form-label">Link System User</label>
                    <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId">
                        <option value="">None</option>
                    </select>
                    <div class="form-text">Optional: Link to an existing login account.</div>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-5">
                <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                <button type="submit" class="btn btn-primary">Save Details</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
