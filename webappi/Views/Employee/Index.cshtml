@model IEnumerable<webappi.Data.ErpEmployee>

@{
    ViewData["Title"] = "Employees";
}

<div class="card card-flush">
    <div class="card-header align-items-center py-5 gap-2 gap-md-5">
        <div class="card-title">
            <h3>Employees</h3>
        </div>
        <div class="card-toolbar">
            <a asp-action="Create" class="btn btn-primary">Add New Employee</a>
        </div>
    </div>
    <div class="card-body pt-0">
        <table class="table align-middle table-row-dashed fs-6 gy-5" id="kt_employees_table">
            <thead>
                <tr class="text-start text-gray-400 fw-bold fs-7 text-uppercase gs-0">
                    <th>Employee</th>
                    <th>Code</th>
                    <th>Dept & Designation</th>
                    <th>Contact</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody class="fw-semibold text-gray-600">
                @foreach (var item in Model) {
                <tr>
                    <td class="d-flex align-items-center">
                        <div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
                            <div class="symbol-label">
                                @if (!string.IsNullOrEmpty(item.PhotoPath))
                                {
                                    <img src="~/images/employees/@item.PhotoPath" alt="@item.FullName" class="w-100" />
                                }
                                else
                                {
                                    <div class="symbol-label fs-3 bg-light-danger text-danger">@item.FirstName.Substring(0,1)</div>
                                }
                            </div>
                        </div>
                        <div class="d-flex flex-column">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-gray-800 text-hover-primary mb-1">@item.FullName</a>
                            <span>@item.Email</span>
                        </div>
                    </td>
                    <td>@item.EmployeeCode</td>
                    <td>
                        <div class="badge badge-light fw-bold">@item.Department?.Name</div>
                        <div class="text-muted fs-7">@item.Designation?.Name</div>
                    </td>
                    <td>@item.ContactNumber</td>
                    <td>
                        <span class="badge badge-light-@(item.Status == "Active" ? "success" : "warning")">@item.Status</span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm">
                            <i class="fas fa-trash"></i>
                        </a>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
