@model webappi.Data.ErpEmployee

@{
    ViewData["Title"] = "Employee Details";
}

<div class="card mb-5 mb-xl-10">
    <div class="card-body pt-9 pb-0">
        <div class="d-flex flex-wrap flex-sm-nowrap mb-3">
            <div class="me-7 mb-4">
                <div class="symbol symbol-100px symbol-lg-160px symbol-fixed position-relative">
                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <img src="~/images/employees/@Model.PhotoPath" alt="@Model.FullName" />
                    }
                    else
                    {
                        <div class="symbol-label fs-1 fw-bold bg-light-primary text-primary">@Model.FirstName.Substring(0,1)</div>
                    }
                    <div class="position-absolute translate-middle bottom-0 start-100 mb-6 bg-@(Model.Status=="Active"?"success":"danger") rounded-circle border border-4 border-white h-20px w-20px"></div>
                </div>
            </div>

            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start flex-wrap mb-2">
                    <div class="d-flex flex-column">
                        <div class="d-flex align-items-center mb-2">
                            <a href="#" class="text-gray-900 text-hover-primary fs-2 fw-bold me-1">@Model.FullName</a>
                            <span class="badge badge-light-primary fw-bold ms-2 fs-8">@Model.EmployeeCode</span>
                        </div>
                        <div class="d-flex flex-wrap fw-semibold fs-6 mb-4 pe-2">
                            <a href="#" class="d-flex align-items-center text-gray-400 text-hover-primary me-5 mb-2">
                                <i class="fas fa-briefcase me-1"></i> @Model.Designation?.Name
                            </a>
                            <a href="#" class="d-flex align-items-center text-gray-400 text-hover-primary me-5 mb-2">
                                <i class="fas fa-building me-1"></i> @Model.Department?.Name
                            </a>
                            <a href="#" class="d-flex align-items-center text-gray-400 text-hover-primary mb-2">
                                <i class="fas fa-envelope me-1"></i> @Model.Email
                            </a>
                        </div>
                    </div>
                     <div class="d-flex my-4">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-primary me-2">Edit</a>
                         <a asp-action="Index" class="btn btn-sm btn-light">Back</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-5 g-xl-10">
    <div class="col-xl-6">
        <div class="card card-flush h-md-100">
            <div class="card-header">
                <div class="card-title">
                    <h2>Personal Information</h2>
                </div>
            </div>
            <div class="card-body pt-1">
                <div class="d-flex flex-stack position-relative mt-6">
                    <div class="fw-bold text-gray-700">Gender</div>
                    <div class="fw-semibold text-gray-900">@Model.Gender</div>
                </div>
                <div class="d-flex flex-stack position-relative mt-6">
                    <div class="fw-bold text-gray-700">Date of Birth</div>
                    <div class="fw-semibold text-gray-900">@Model.DateOfBirth?.ToShortDateString()</div>
                </div>
                 <div class="d-flex flex-stack position-relative mt-6">
                    <div class="fw-bold text-gray-700">Contact</div>
                    <div class="fw-semibold text-gray-900">@Model.ContactNumber</div>
                </div>
                 <div class="d-flex flex-stack position-relative mt-6">
                    <div class="fw-bold text-gray-700">Address</div>
                    <div class="fw-semibold text-gray-900">@Model.Address</div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-6">
        <div class="card card-flush h-md-100">
             <div class="card-header">
                <div class="card-title">
                    <h2>Employment Details</h2>
                </div>
            </div>
            <div class="card-body pt-1">
                 <div class="d-flex flex-stack position-relative mt-6">
                    <div class="fw-bold text-gray-700">Date of Joining</div>
                    <div class="fw-semibold text-gray-900">@Model.DateOfJoining.ToShortDateString()</div>
                </div>
                 <div class="d-flex flex-stack position-relative mt-6">
                    <div class="fw-bold text-gray-700">Employment Type</div>
                    <div class="fw-semibold text-gray-900">@Model.EmploymentType</div>
                </div>
                 <div class="d-flex flex-stack position-relative mt-6">
                    <div class="fw-bold text-gray-700">System User</div>
                    <div class="fw-semibold text-gray-900">@(Model.User?.Email ?? "Not Linked")</div>
                </div>
                <hr />
                 <div class="fw-bold text-gray-700 mb-2">Emergency Contact</div>
                 <div class="fw-semibold text-gray-900">
                     @Model.EmergencyContactName - @Model.EmergencyContactNumber
                 </div>
            </div>
        </div>
    </div>
</div>
