@model List<webappi.Data.ErpModule>
@{
    ViewData["Title"] = "Modules";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Modules Management</h1>
        <p class="text-muted">Manage system functional modules.</p>
    </div>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModuleModal">
        <i class="lni lni-plus"></i> Add Module
    </button>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Module Name</th>
                        <th>Code</th>
                        <th>Description</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mod in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@mod.ModuleName</td>
                            <td><code class="text-primary bg-light px-2 py-1 rounded">@mod.ModuleCode</code></td>
                            <td class="text-muted small">@mod.Description</td>
                            <td>
                                @if (mod.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Inactive</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModuleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="/SuperAdmin/CreateModule">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Module</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Module Name</label>
                        <input type="text" name="ModuleName" class="form-control" placeholder="e.g. Human Resources" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Module Code</label>
                        <input type="text" name="ModuleCode" class="form-control" placeholder="e.g. HR" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="3" placeholder="Description of the module..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Module</button>
                </div>
            </form>
        </div>
    </div>
</div>
