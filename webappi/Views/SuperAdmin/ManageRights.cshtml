@model webappi.Models.ManageRightsViewModel
@{
    ViewData["Title"] = "Manage Rights - " + Model.UserName;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Manage Rights</h1>
        <p class="text-muted">Edit subscriptions for <strong>@Model.UserName</strong></p>
    </div>
    <a asp-action="Clients" class="btn btn-outline-secondary">
        <i class="lni lni-arrow-left"></i> Back to Clients
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form asp-action="ManageRights" method="post">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserName" />

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px;">Select</th>
                            <th>Module</th>
                            <th style="width: 200px;">Start Date</th>
                            <th style="width: 200px;">Expiry Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Modules.Count; i++)
                        {
                            <tr class="module-row">
                                <td>
                                    <input type="hidden" asp-for="Modules[i].ModuleId" />
                                    <input type="hidden" asp-for="Modules[i].ModuleName" />
                                    <div class="form-check">
                                        <input class="form-check-input module-chk" type="checkbox" asp-for="Modules[i].IsSelected" 
                                               onchange="toggleRow(this)" />
                                    </div>
                                </td>
                                <td class="fw-medium">@Model.Modules[i].ModuleName</td>
                                <td>
                                    <input type="date" class="form-control form-control-sm start-date" asp-for="Modules[i].StartDate" disabled="@(!Model.Modules[i].IsSelected)" />
                                </td>
                                <td>
                                    <input type="date" class="form-control form-control-sm expiry-date" asp-for="Modules[i].ExpiryDate" disabled="@(!Model.Modules[i].IsSelected)" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="lni lni-save"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleRow(chk) {
            const row = chk.closest('tr');
            const inputs = row.querySelectorAll('input[type="date"]');
            inputs.forEach(input => {
                input.disabled = !chk.checked;
                if(chk.checked && !input.value) {
                    // Default dates
                    if(input.classList.contains('start-date')) {
                        input.valueAsDate = new Date();
                    } else {
                        let d = new Date();
                        d.setFullYear(d.getFullYear() + 1);
                        input.valueAsDate = d;
                    }
                }
            });
        }
    </script>
}
