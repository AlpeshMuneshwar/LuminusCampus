@model List<webappi.Data.ErpPage>
@{
    ViewData["Title"] = "Pages";
    var modules = ViewBag.Modules as List<webappi.Data.ErpModule>;
    var groupByModule = Model.GroupBy(p => p.Module);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Pages Management</h1>
        <p class="text-muted">Manage system pages grouped by their modules.</p>
    </div>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createPageModal">
        <i class="lni lni-plus"></i> Add Page
    </button>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No pages found. Start by adding one.</div>
}
else
{
    <div class="accordion" id="modulesAccordion">
        @foreach (var group in groupByModule)
        {
            var moduleName = group.Key?.ModuleName ?? "Unassigned";
            var moduleId = group.Key?.Id ?? 0;
            var collapseId = $"collapse-{moduleId}";

            <div class="card mb-3 shadow-sm border-0">
                <div class="card-header bg-white" id="heading-@moduleId">
                    <h5 class="mb-0">
                        <button class="btn btn-link w-100 text-start text-decoration-none text-dark d-flex justify-content-between align-items-center" 
                                type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                            <span>
                                <i class="lni lni-grid-alt me-2"></i> @moduleName
                                <span class="badge bg-secondary ms-2">@group.Count() Pages</span>
                            </span>
                            <i class="lni lni-chevron-down"></i>
                        </button>
                    </h5>
                </div>

                <div id="@collapseId" class="collapse show" data-bs-parent="#modulesAccordion">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Page Name</th>
                                        <th>Description</th>
                                        <th>URL Path</th>
                                        <th class="text-end pe-4">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in group)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-medium">@item.PageName</td>
                                            <td class="text-muted small">@item.Description</td>
                                            <td><code class="text-primary bg-light px-2 py-1 rounded">@item.PageUrl</code></td>
                                            <td class="text-end pe-4">
                                                <button class="btn btn-sm btn-outline-primary me-2" 
                                                       data-bs-toggle="modal" 
                                                       data-bs-target="#editPageModal-@item.Id">
                                                    <i class="lni lni-pencil"></i> Edit
                                                </button>
                                                <form asp-action="DeletePage" asp-route-id="@item.Id" method="post" 
                                                      class="d-inline" onsubmit="return confirm('Are you sure you want to delete this page?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="lni lni-trash-can"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>

                                        <!-- Edit Modal per Item (Simple implementation) -->
                                        <div class="modal fade" id="editPageModal-@item.Id" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <form method="post" action="/SuperAdmin/UpdatePage">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Edit Page</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <input type="hidden" name="Id" value="@item.Id" />
                                                            <div class="mb-3">
                                                                <label class="form-label">Module</label>
                                                                <select name="ModuleId" class="form-select" required>
                                                                    @foreach (var m in modules)
                                                                    {
                                                                        <option value="@m.Id" selected="@(m.Id == item.ModuleId)">@m.ModuleName</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                            <div class="mb-3">
                                                                <label class="form-label">Page Name</label>
                                                                <input type="text" name="PageName" class="form-control" value="@item.PageName" required>
                                                            </div>
                                                            <div class="mb-3">
                                                                <label class="form-label">Description</label>
                                                                <textarea name="Description" class="form-control" rows="2">@item.Description</textarea>
                                                            </div>
                                                            <div class="mb-3">
                                                                <label class="form-label">Page URL</label>
                                                                <input type="text" name="PageUrl" class="form-control" value="@item.PageUrl" required>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-primary">Save Changes</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Create Modal -->
<div class="modal fade" id="createPageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="/SuperAdmin/CreatePage">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Page</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Module</label>
                        <select name="ModuleId" class="form-select" required>
                            <option value="">Select a Module...</option>
                            @foreach (var m in modules)
                            {
                                <option value="@m.Id">@m.ModuleName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Page Name</label>
                        <input type="text" name="PageName" class="form-control" placeholder="e.g. Student Registration" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="2" placeholder="Brief description of the page"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Page URL</label>
                        <input type="text" name="PageUrl" class="form-control" placeholder="e.g. /SIS/Registration" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Page</button>
                </div>
            </form>
        </div>
    </div>
</div>
